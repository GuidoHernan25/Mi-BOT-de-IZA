{
  "name": "stockbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend base para pedidos de stock por WhatsApp, reservas y validacion de salidas.",

  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run db:generate && tsc",
    "start": "node dist/src/server.js",

    "postinstall": "prisma generate",

    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",

    "import:izaenergy": "tsx scripts/import-izaenergy.ts",
    "evolution:setup": "tsx scripts/evolution-setup.ts",
    "simulate:order": "tsx scripts/simulate-order.ts",

    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },

  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@prisma/client": "^6.14.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },

  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.19.19",
    "eslint": "^9.19.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0"
  },

  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}